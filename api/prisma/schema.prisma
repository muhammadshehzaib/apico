generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  workpaces WorkspaceMember[]
  invitesSent     WorkspaceInvite[] @relation("WorkspaceInviteInviter")
  invitesAccepted WorkspaceInvite[] @relation("WorkspaceInviteAccepter")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   WorkspaceMember[]
  invites   WorkspaceInvite[]
  folders   Folder[]
  tags      Tag[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model WorkspaceInvite {
  id          String                @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole         @default(VIEWER)
  token       String                @unique
  status      WorkspaceInviteStatus @default(PENDING)
  invitedById String
  acceptedById String?
  createdAt   DateTime              @default(now())
  expiresAt   DateTime?
  acceptedAt  DateTime?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("WorkspaceInviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy  User?     @relation("WorkspaceInviteAccepter", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, email, status])
}

model Collection {
  id          String         @id @default(cuid())
  name        String
  workspaceId String
  folderId    String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  requests    SavedRequest[]
  sharedLinks SharedCollectionLink[]
  folder      Folder?        @relation(fields: [folderId], references: [id], onDelete: SetNull)
}

model SavedRequest {
  id           String       @id @default(cuid())
  name         String
  collectionId String
  method       HttpMethod
  url          String
  headers      Json         @default("[]")
  params       Json         @default("[]")
  body         String?
  auth         Json?
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  collection   Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  sharedLinks  SharedLink[]
  tags         RequestTag[]
}

model RequestHistory {
  id         String     @id @default(cuid())
  userId     String
  method     HttpMethod
  url        String
  headers    Json       @default("[]")
  body       String?
  statusCode Int?
  response   String?    @db.Text
  duration   Int?
  size       Int?
  createdAt  DateTime   @default(now())
}

model SharedLink {
  id             String       @id @default(cuid())
  savedRequestId String
  token          String       @unique
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?
  savedRequest   SavedRequest @relation(fields: [savedRequestId], references: [id], onDelete: Cascade)
}

model SharedCollectionLink {
  id           String      @id @default(cuid())
  collectionId String
  token        String      @unique
  createdAt    DateTime    @default(now())
  expiresAt    DateTime?
  collection   Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

model Environment {
  id        String   @id @default(cuid())
  name      String
  workspaceId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EnvironmentVariable {
  id            String   @id @default(cuid())
  environmentId String
  key           String
  value         String
  enabled       Boolean  @default(true)
  isSecret      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Folder {
  id          String    @id @default(cuid())
  name        String
  workspaceId String
  parentId    String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Folder?   @relation("FolderParent", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]  @relation("FolderParent")
  collections Collection[]

  @@index([workspaceId, parentId])
}

model Tag {
  id          String    @id @default(cuid())
  name        String
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requests    RequestTag[]

  @@unique([workspaceId, name])
}

model RequestTag {
  id         String       @id @default(cuid())
  requestId  String
  tagId      String
  createdAt  DateTime     @default(now())
  request    SavedRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  tag        Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([requestId, tagId])
  @@index([tagId])
}
